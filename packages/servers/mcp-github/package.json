{
  "name": "github-server",
  "version": "1.0.0",
  "description": "A Model Context Protocol server for GitHub API operations",
  "private": true,
  "type": "module",
  "bin": {
    "github-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js",
    "test-inspector": "node inspector-test.js",
    "start-inspector": "./start-inspector.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "axios": "^1.12.2",
    "mcp-utils": "*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "typescript": "^5.8.3"
  }
}
