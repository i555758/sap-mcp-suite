{
  "name": "sap-jira-mcp",
  "version": "2.0.3",
  "description": "MCP server for SAP Jira search and ticket management functionality",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "sap-jira-mcp": "./bin/sap-jira-mcp.js"
  },
  "files": [
    "dist/",
    "bin/",
    "src/",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); fs.mkdirSync('dist',{recursive:true}); fs.copyFileSync('src/jql_examples.md','dist/jql_examples.md'); try{fs.copyFileSync('.jira-config.json','dist/.jira-config.json')}catch(e){}\"",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@anthropic/sap-auth": "*",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "axios": "^1.12.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "mcp",
    "sap",
    "jira",
    "tickets",
    "search"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.tools.sap/sfsfmcp/sap-jira-mcp.git"
  },
  "bugs": {
    "url": "https://github.tools.sap/sfsfmcp/sap-jira-mcp/issues"
  },
  "homepage": "https://github.tools.sap/sfsfmcp/sap-jira-mcp#readme",
  "author": "",
  "license": "MIT",
  "volta": {
    "node": "20.19.5"
  }
}
