{
  "name": "sap-wiki-mcp",
  "version": "1.1.1",
  "description": "MCP server for SAP Wiki search functionality",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "sap-wiki-mcp": "./bin/sap-wiki-mcp.js"
  },
  "files": [
    "dist/",
    "bin/",
    "src/",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "debug": "tsc && node --inspect dist/index.js",
    "test:url": "tsc && node -e \"const { PureWikiHttpClient } = require('./dist/pure-http-client.js'); async function test() { const c = new PureWikiHttpClient(); await c.initialize(); const r = await c.fetchWikiContent(process.argv[1], true); console.log(r.substring(0,3000)); } test().catch(e => console.error(e.message));\""
  },
  "dependencies": {
    "@anthropic/sap-auth": "*",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "axios": "^1.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "mcp",
    "sap",
    "wiki",
    "search"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.tools.sap/sfsfmcp/sap-wiki-mcp.git"
  },
  "bugs": {
    "url": "https://github.tools.sap/sfsfmcp/sap-wiki-mcp/issues"
  },
  "homepage": "https://github.tools.sap/sfsfmcp/sap-wiki-mcp#readme",
  "author": "",
  "license": "MIT",
  "volta": {
    "node": "20.19.5"
  }
}
