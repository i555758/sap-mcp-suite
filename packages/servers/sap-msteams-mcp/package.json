{
  "name": "sap-msteams-mcp",
  "version": "1.0.0",
  "description": "MCP server for Microsoft Teams access via SAP SSO authentication",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "sap-msteams-mcp": "./bin/sap-msteams-mcp.js"
  },
  "files": [
    "dist/",
    "bin/",
    "src/",
    "tsconfig.json"
  ],
  "scripts": {
