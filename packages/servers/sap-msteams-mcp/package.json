  },
  "bugs": {
    "url": "https://github.tools.sap/sfsfmcp/sap-msteams-mcp/issues"
  },
  "homepage": "https://github.tools.sap/sfsfmcp/sap-msteams-mcp#readme",
  "author": "",
  "license": "MIT",
  "dependencies": {
    "sap-auth": "*",
    "mcp-utils": "*",
    "mcp-logger": "*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "volta": {
    "node": "20.19.5"
  }
